---
import Layout from '../layouts/Layout.astro';
import '../styles/reset.css';
import '../styles/style.css';

// Dynamic import for hot-reload during development
import { readFileSync } from 'fs';
import { fileURLToPath } from 'url';
import { dirname, join } from 'path';

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);
const contentPath = join(__dirname, '../../content/pages/home.json');
const content = JSON.parse(readFileSync(contentPath, 'utf-8'));
---

<Layout title={content.title} description={content.description}>
  <!-- Mobile-only Quick CTA -->
  <a href="#contact" class="mobile-cta-fab" aria-label="Quick order">
    <span>🍅</span>
  </a>

  <header class="hero" id="top">
    <div class="hero-bg"></div>
    <nav class="nav">
      <a class="brand" href="#top">
        <span class="brand-dot"></span>
        G.T.Boleac Anatolie Filip
      </a>
      <div class="nav-links">
        <a href="#services">Services</a>
        <a href="#benefits">Why us</a>
        <a href="#contact">Contact</a>
      </div>
      <a class="button primary" href="#contact">Make an order</a>
    </nav>

    <section class="hero-content">
      <div class="hero-copy">
        <p class="eyebrow">{content.hero.eyebrow}</p>
        <h1>{content.hero.heading}</h1>
        <p class="lead">
          {content.hero.lead}
        </p>
        <div class="hero-actions d-flex gap-3 flex-wrap">
          <a class="button primary" href="#contact">Make an order</a>
          <a class="button ghost" href="#services">Explore services</a>
        </div>
        <div class="hero-metrics row g-3">
          {content.hero.metrics.map((metric) => (
            <div class="col-auto">
              <h3 class="mb-1">{metric.value}</h3>
              <p class="mb-0">{metric.label}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="hero-art" aria-hidden="true">
        <div class="tomato-card">
          <span>Make a contract</span>
          <strong>Large quantity</strong>
          <p>only for the summer season</p>
        </div>
        <div class="tomato-orb"></div>
        <div class="tomato-orb small"></div>
        <div class="tomato-leaf"></div>
      </div>
    </section>
  </header>

  <main>
    <section class="section" id="services">
      <div class="section-header">
        <p class="eyebrow">Services</p>
        <h2>{content.services.heading}</h2>
      </div>
      <div class="card-grid row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        {content.services.items.map((service) => (
          <div class="col">
            <article class="card h-100">
              <div class="card-icon">{service.icon}</div>
              <h3>{service.title}</h3>
              <p>{service.description}</p>
              <a href="#contact" class="mt-auto">Learn more</a>
            </article>
          </div>
        ))}
      </div>
    </section>

    <section class="section split" id="benefits">
      <div class="col-lg-5">
        <p class="eyebrow">Why us?</p>
        <h2>{content.benefits.heading}</h2>
        <p class="lead">
          Our breeding program prioritizes taste, disease resistance, and
          consistent harvests.
        </p>
        <div class="pill-list d-flex flex-wrap gap-2">
          <span class="badge">Cash</span>
          <span class="badge">Bill</span>
        </div>
      </div>
      <div class="benefit-grid col-lg-7">
        {content.benefits.items.map((benefit, index) => (
          <div class={index === content.benefits.items.length - 1 ? "benefit mb-0" : "benefit mb-3"}>
            <div class="benefit-icon">{benefit.icon}</div>
            <h3>{benefit.title}</h3>
            <p class="mb-0">{benefit.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Mobile-only promotional banner -->
    <section class="mobile-only-promo">
      <div class="promo-content">
        <h3>{content.promo.heading}</h3>
        <p>{content.promo.description}</p>
        <a href="#contact" class="button primary">{content.promo.buttonText}</a>
      </div>
    </section>

    <section class="section contact" id="contact">
      <div class="section-header">
        <p class="eyebrow">Contact</p>
        <h2>Make the world tastier with us.</h2>
      </div>
      <div class="contact-grid row g-4">
        <div class="col-md-6 col-lg-5">
          <div class="contact-card">
            <h3>Make an order</h3>
            <p class="mb-2">{content.contact.schedule}</p>
            <p class="mb-2">{content.contact.address}</p>
            <p class="mb-2">{content.contact.phone}</p>
            <p class="mb-0">{content.contact.email}</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-7">
          <form class="contact-form">
            <div class="mb-3">
              <label class="form-label" for="name">Full name</label>
              <input type="text" id="name" name="name" class="form-control" placeholder="Your name" />
            </div>
            <div class="mb-3">
              <label class="form-label" for="email">Email</label>
              <input type="email" id="email" name="email" class="form-control" placeholder="you@email.com" />
            </div>
            <div class="mb-3">
              <label class="form-label" for="message">What do you want to buy, and what quantity?</label>
              <textarea id="message" name="message" rows="4" class="form-control" placeholder="Tell us about your plot."></textarea>
            </div>
            <button class="button primary" type="submit">Send request</button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <p>G.T.Boleac Anatolie Filip. Breeding bold tomatoes since 2004.</p>
    <a href="#top">Back to top</a>
  </footer>

  <!--

 Animated Mascot -->
  <div class="mascot" id="tomato-mascot">
    <div class="mascot-character">
      <svg viewBox="0 0 100 120" xmlns="http://www.w3.org/2000/svg">
        <!-- Tomato body -->
        <ellipse cx="50" cy="70" rx="35" ry="38" fill="#e4473b"/>
        <ellipse cx="40" cy="60" rx="8" ry="10" fill="#f57d6e" opacity="0.6"/>
        
        <!-- Stem and leaves -->
        <rect x="47" y="30" width="6" height="15" fill="#2e7b52" rx="2"/>
        <ellipse cx="35" cy="35" rx="12" ry="6" fill="#2e7b52" transform="rotate(-25 35 35)"/>
        <ellipse cx="65" cy="35" rx="12" ry="6" fill="#2e7b52" transform="rotate(25 65 35)"/>
        <ellipse cx="50" cy="28" rx="10" ry="5" fill="#2e7b52"/>
        
        <!-- Eyes -->
        <circle cx="40" cy="68" r="4" fill="#1f1c1a"/>
        <circle cx="60" cy="68" r="4" fill="#1f1c1a"/>
        <circle cx="41" cy="67" r="1.5" fill="white"/>
        <circle cx="61" cy="67" r="1.5" fill="white"/>
        
        <!-- Smile -->
        <path d="M 38 78 Q 50 85 62 78" stroke="#1f1c1a" stroke-width="2" fill="none" stroke-linecap="round"/>
        
        <!-- Rosy cheeks -->
        <ellipse cx="32" cy="75" rx="4" ry="3" fill="#f1644b" opacity="0.5"/>
        <ellipse cx="68" cy="75" rx="4" ry="3" fill="#f1644b" opacity="0.5"/>
      </svg>
    </div>
    <div class="mascot-tooltip">
      <p>🎉 Welcome! Want the tastiest tomatoes?</p>
      <a href="#contact">Order Now →</a>
    </div>
  </div>

  <script>
    // Mascot appears after 2 second delay
    setTimeout(() => {
      document.getElementById('tomato-mascot').classList.add('visible');
    }, 2000);
  </script>
</Layout>
